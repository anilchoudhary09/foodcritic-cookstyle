#!/usr/bin/env bash
#
# cookstyle-barc - Wrapper script to run Cookstyle with Barclays BARC rules
#
# This script automatically finds the b-cookstyle-rules directory and runs
# cookstyle with the correct configuration. Developers don't need to add
# .rubocop.yml to each cookbook.
#
# Installation:
#   1. Copy this script to a directory in your PATH (e.g., /usr/local/bin/)
#   2. Make it executable: chmod +x /usr/local/bin/cookstyle-barc
#
# Usage:
#   cd /path/to/your/cookbook
#   cookstyle-barc .                    # Run all checks
#   cookstyle-barc --autocorrect .      # Auto-fix issues
#   cookstyle-barc --format json .      # JSON output
#
# Environment Variables:
#   BARC_RULES_PATH - Override path to b-cookstyle-rules directory
#
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Find b-cookstyle-rules directory
find_barc_rules() {
    # Check environment variable first
    if [ -n "$BARC_RULES_PATH" ] && [ -d "$BARC_RULES_PATH" ]; then
        echo "$BARC_RULES_PATH"
        return 0
    fi
    
    # Common locations to check
    local locations=(
        "../b-cookstyle-rules"
        "../../b-cookstyle-rules"
        "../cookbooks/b-cookstyle-rules"
        "../../cookbooks/b-cookstyle-rules"
        "$HOME/chef/b-cookstyle-rules"
        "/opt/chef/b-cookstyle-rules"
    )
    
    for loc in "${locations[@]}"; do
        if [ -f "$loc/barc_cops.rb" ]; then
            # Convert to absolute path
            echo "$(cd "$loc" && pwd)"
            return 0
        fi
    done
    
    return 1
}

# Main
main() {
    echo -e "${BLUE}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║           COOKSTYLE WITH BARCLAYS BARC RULES              ║${NC}"
    echo -e "${BLUE}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Find BARC rules directory
    BARC_DIR=$(find_barc_rules)
    
    if [ -z "$BARC_DIR" ]; then
        echo -e "${RED}ERROR: Could not find b-cookstyle-rules directory${NC}"
        echo ""
        echo "Please set BARC_RULES_PATH environment variable:"
        echo "  export BARC_RULES_PATH=/path/to/b-cookstyle-rules"
        echo ""
        echo "Or ensure b-cookstyle-rules is in a standard location:"
        echo "  - ../b-cookstyle-rules"
        echo "  - ../cookbooks/b-cookstyle-rules"
        exit 1
    fi
    
    echo -e "${GREEN}Found BARC rules at: ${BARC_DIR}${NC}"
    echo ""
    
    # Check if cookstyle is installed
    if ! command -v cookstyle &> /dev/null; then
        echo -e "${RED}ERROR: cookstyle not found. Please install it:${NC}"
        echo "  gem install cookstyle"
        exit 1
    fi
    
    echo -e "Cookstyle version: $(cookstyle --version)"
    echo -e "Running in: $(pwd)"
    echo ""
    
    # Build cookstyle command
    # The --require flag loads barc_cops.rb
    # The --config flag uses the central configuration
    cookstyle \
        --require "${BARC_DIR}/barc_cops.rb" \
        --config "${BARC_DIR}/.rubocop.yml" \
        "$@"
}

main "$@"
