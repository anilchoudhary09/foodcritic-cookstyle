<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      background: <%= status == 'success' ? '#28a745' : '#dc3545' %>;
      color: white;
      padding: 20px;
      border-radius: 8px 8px 0 0;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 1.5rem;
    }
    .content {
      background: #fff;
      border: 1px solid #ddd;
      border-top: none;
      padding: 20px;
      border-radius: 0 0 8px 8px;
    }
    .status-badge {
      display: inline-block;
      padding: 5px 15px;
      border-radius: 20px;
      font-weight: bold;
      font-size: 0.9rem;
    }
    .success { background: #d4edda; color: #155724; }
    .failure { background: #f8d7da; color: #721c24; }
    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }
    .info-table th,
    .info-table td {
      padding: 10px;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    .info-table th {
      width: 40%;
      color: #666;
    }
    .summary-box {
      background: #f8f9fa;
      padding: 15px;
      border-radius: 5px;
      margin: 15px 0;
    }
    .summary-box h3 {
      margin-top: 0;
      color: #333;
    }
    .violation-count {
      font-size: 2rem;
      font-weight: bold;
    }
    .violation-count.zero { color: #28a745; }
    .violation-count.high { color: #dc3545; }
    .btn {
      display: inline-block;
      padding: 10px 20px;
      background: #0066cc;
      color: white;
      text-decoration: none;
      border-radius: 5px;
      margin: 10px 5px 10px 0;
    }
    .btn:hover {
      background: #0055aa;
    }
    .footer {
      text-align: center;
      color: #666;
      font-size: 0.85rem;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid #eee;
    }
    .severity-list {
      list-style: none;
      padding: 0;
    }
    .severity-list li {
      padding: 5px 0;
    }
    .severity-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 0.8rem;
      margin-right: 10px;
    }
    .severity-error { background: #dc3545; color: white; }
    .severity-warning { background: #ffc107; color: #333; }
    .severity-convention { background: #17a2b8; color: white; }
  </style>
</head>
<body>
  <div class="header">
    <h1>
      <%= status == 'success' ? '✓' : '✗' %>
      Cookbook Compliance: <%= cookbook_name %>
    </h1>
  </div>

  <div class="content">
    <p>
      <span class="status-badge <%= status %>">
        <%= status == 'success' ? 'PASSED' : 'FAILED' %>
      </span>
    </p>

    <table class="info-table">
      <tr>
        <th>Cookbook</th>
        <td><strong><%= cookbook_name %></strong></td>
      </tr>
      <tr>
        <th>Source</th>
        <td><%= source_type %></td>
      </tr>
      <tr>
        <th>Build Number</th>
        <td>#<%= build_number %></td>
      </tr>
      <tr>
        <th>Timestamp</th>
        <td><%= timestamp %></td>
      </tr>
    </table>

    <div class="summary-box">
      <h3>Compliance Summary</h3>
      <div class="violation-count <%= violation_count == 0 ? 'zero' : 'high' %>">
        <%= violation_count %> Violation<%= violation_count == 1 ? '' : 's' %>
      </div>

      <% if violation_count > 0 %>
      <ul class="severity-list">
        <% violations_by_severity.each do |severity, count| %>
        <li>
          <span class="severity-badge severity-<%= severity %>"><%= severity %></span>
          <%= count %> issue<%= count == 1 ? '' : 's' %>
        </li>
        <% end %>
      </ul>
      <% end %>
    </div>

    <p>
      <a href="<%= build_url %>" class="btn">View Build</a>
      <a href="<%= report_url %>" class="btn">View Full Report</a>
    </p>

    <% if status != 'success' %>
    <p style="color: #666; font-size: 0.9rem;">
      Please review the compliance report and fix any violations before merging.
      <% if correctable_count > 0 %>
      Note: <%= correctable_count %> violation<%= correctable_count == 1 ? ' is' : 's are' %> auto-correctable.
      <% end %>
    </p>
    <% end %>
  </div>

  <div class="footer">
    <p>Barclays Chef Compliance Pipeline</p>
    <p>This is an automated message from Jenkins.</p>
  </div>
</body>
</html>
