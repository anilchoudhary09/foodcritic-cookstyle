# Test Kitchen EC2 - Git Ignore

# Kitchen files
.kitchen/
kitchen.local.yml

# Vendored cookbooks (regenerated by berks)
cookbooks/

# Berkshelf
Berksfile.lock

# Ruby
*.gem
.bundle/
vendor/bundle/

# Reports
*.json
*.html
*.tar.gz

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Credentials (NEVER commit)
*.pem
*.key
credentials.yml
secrets.yml
