// Jenkinsfile for Test Kitchen EC2 Convergence Testing
//
// This pipeline runs cookstyle validation with BARC rules followed by
// Test Kitchen converge on an existing EC2 instance
//
// The EC2 instance has Chef Workstation 25 pre-installed
// All Chef commands run remotely via SSH on the EC2 instance

pipeline {
    agent any

    environment {
        // EC2 Instance Configuration - Store these in Jenkins credentials
        EC2_HOST = credentials('ec2-kitchen-host')  // Secret text: EC2 hostname
        SSH_KEY = credentials('ec2-ssh-key')        // Secret file: SSH private key (.pem)
        SSH_USER = 'ec2-user'

        // Remote paths on EC2
        REMOTE_WORKSPACE = '/home/ec2-user/kitchen-test'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
    }

    parameters {
        choice(
            name: 'SUITE',
            choices: ['compliant', 'my-app', 'all'],
            description: 'Test Kitchen suite to run'
        )
        choice(
            name: 'ACTION',
            choices: ['converge', 'verify', 'test', 'destroy'],
            description: 'Test Kitchen action to perform'
        )
        booleanParam(
            name: 'RUN_COOKSTYLE',
            defaultValue: true,
            description: 'Run Cookstyle with BARC rules before converge'
        )
        string(
            name: 'COOKBOOK_TO_TEST',
            defaultValue: 'compliant-cookbook',
            description: 'Cookbook to validate with Cookstyle'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'ls -la'
            }
        }

        stage('Verify EC2 Connection') {
            steps {
                script {
                    sh '''
                        echo "=== Testing SSH Connection to EC2 ==="
                        chmod 400 ${SSH_KEY}

                        ssh -o StrictHostKeyChecking=no -o ConnectTimeout=30 \
                            -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} \
                            "echo 'SSH Connection Successful' && uname -a"

                        echo ""
                        echo "=== Chef Workstation Version on EC2 ==="
                        ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} \
                            "chef --version"
                    '''
                }
            }
        }

        stage('Transfer Files to EC2') {
            steps {
                script {
                    sh '''
                        echo "=== Preparing Remote Workspace ==="

                        # Create remote workspace
                        ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} \
                            "rm -rf ${REMOTE_WORKSPACE} && mkdir -p ${REMOTE_WORKSPACE}/.ssh"

                        echo "=== Transferring SSH Key to EC2 ==="
                        
                        # Transfer SSH key for kitchen to use
                        scp -i ${SSH_KEY} ${SSH_KEY} \
                            ${SSH_USER}@${EC2_HOST}:${REMOTE_WORKSPACE}/.ssh/kitchen-key.pem
                        
                        # Set correct permissions on the key
                        ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} \
                            "chmod 400 ${REMOTE_WORKSPACE}/.ssh/kitchen-key.pem"

                        echo "=== Transferring Cookbooks to EC2 ==="

                        # Transfer cookbooks
                        scp -i ${SSH_KEY} -r ${WORKSPACE}/cookbooks \
                            ${SSH_USER}@${EC2_HOST}:${REMOTE_WORKSPACE}/

                        # Transfer test-kitchen-ec2 config
                        scp -i ${SSH_KEY} -r ${WORKSPACE}/test-kitchen-ec2 \
                            ${SSH_USER}@${EC2_HOST}:${REMOTE_WORKSPACE}/
                        
                        echo "=== Creating kitchen.local.yml with correct SSH key path ==="
                        
                        # Create kitchen.local.yml with EC2-specific paths
                        ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} "
                            cat > ${REMOTE_WORKSPACE}/test-kitchen-ec2/kitchen.local.yml << 'KITCHENEOF'
---
transport:
  ssh_key: ${REMOTE_WORKSPACE}/.ssh/kitchen-key.pem
  
driver:
  host: localhost

platforms:
  - name: amazon-linux-2023
    driver:
      host: localhost
    transport:
      hostname: localhost
KITCHENEOF
                            echo 'kitchen.local.yml created:'
                            cat ${REMOTE_WORKSPACE}/test-kitchen-ec2/kitchen.local.yml
                        "

                        echo ""
                        echo "=== Remote Workspace Contents ==="
                        ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} \
                            "ls -la ${REMOTE_WORKSPACE}/"
                    '''
                }
            }
        }

        stage('Cookstyle Validation') {
            when {
                expression { params.RUN_COOKSTYLE == true }
            }
            steps {
                script {
                    def cookbook = params.COOKBOOK_TO_TEST
                    echo "Running Cookstyle with BARC rules on ${cookbook}"

                    sh """
                        echo "=== Cookstyle BARC Rules Validation ==="
                        echo "Cookbook: ${cookbook}"
                        echo ""

                        ssh -i \${SSH_KEY} \${SSH_USER}@\${EC2_HOST} '
                            cd ${REMOTE_WORKSPACE}

                            echo "Running cookstyle on ${cookbook}..."
                            cookstyle cookbooks/${cookbook} \
                                --config cookbooks/b-cookstyle-rules/.rubocop.yml \
                                --format progress \
                                --format json --out cookstyle-report.json || true

                            echo ""
                            echo "=== Cookstyle Summary ==="
                            cookstyle cookbooks/${cookbook} \
                                --config cookbooks/b-cookstyle-rules/.rubocop.yml \
                                --format simple || true
                        '

                        # Download report
                        scp -i \${SSH_KEY} \${SSH_USER}@\${EC2_HOST}:${REMOTE_WORKSPACE}/cookstyle-report.json \
                            \${WORKSPACE}/ || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'cookstyle-report.json', allowEmptyArchive: true
                }
            }
        }

        stage('Resolve Dependencies') {
            steps {
                sh '''
                    echo "=== Resolving Cookbook Dependencies ==="

                    ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} "
                        cd ${REMOTE_WORKSPACE}/test-kitchen-ec2

                        echo 'Running berks vendor...'
                        rm -rf cookbooks
                        berks vendor cookbooks

                        echo ''
                        echo '=== Vendored Cookbooks ==='
                        ls -la cookbooks/
                    "
                '''
            }
        }

        stage('Kitchen List') {
            steps {
                sh '''
                    echo "=== Available Kitchen Instances ==="

                    ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} "
                        cd ${REMOTE_WORKSPACE}/test-kitchen-ec2
                        kitchen list
                    "
                '''
            }
        }

        stage('Kitchen Converge') {
            steps {
                script {
                    def suite = params.SUITE
                    def action = params.ACTION
                    def instance = suite == 'all' ? '' : "${suite}-amazon-linux-2023"

                    echo "Running kitchen ${action} on ${suite == 'all' ? 'all instances' : instance}"

                    sh """
                        echo "=============================================="
                        echo "  Test Kitchen ${action.toUpperCase()}"
                        echo "  Instance: ${instance ?: 'ALL'}"
                        echo "=============================================="
                        echo ""

                        ssh -i \${SSH_KEY} \${SSH_USER}@\${EC2_HOST} '
                            cd ${REMOTE_WORKSPACE}/test-kitchen-ec2

                            # Set environment for kitchen
                            export CHEF_LICENSE=accept-silent

                            # Run kitchen action
                            kitchen ${action} ${instance}
                        '

                        echo ""
                        echo "=============================================="
                        echo "  Kitchen ${action.toUpperCase()} Complete!"
                        echo "=============================================="
                    """
                }
            }
        }

        stage('Kitchen Status') {
            steps {
                sh '''
                    echo "=== Final Kitchen Status ==="

                    ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} "
                        cd ${REMOTE_WORKSPACE}/test-kitchen-ec2
                        kitchen list
                    "
                '''
            }
        }

        stage('Collect Logs') {
            steps {
                sh '''
                    echo "=== Collecting Kitchen Logs ==="

                    mkdir -p ${WORKSPACE}/kitchen-logs

                    # Download logs from EC2
                    scp -i ${SSH_KEY} -r \
                        ${SSH_USER}@${EC2_HOST}:${REMOTE_WORKSPACE}/test-kitchen-ec2/.kitchen/logs/* \
                        ${WORKSPACE}/kitchen-logs/ || true

                    ls -la ${WORKSPACE}/kitchen-logs/ || true
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'kitchen-logs/**', allowEmptyArchive: true
        }

        success {
            echo '''
╔══════════════════════════════════════════════════════════════╗
║                    BUILD SUCCESSFUL                          ║
║                                                              ║
║  Cookstyle validation and Kitchen converge completed!        ║
╚══════════════════════════════════════════════════════════════╝
'''
        }

        failure {
            echo '''
╔══════════════════════════════════════════════════════════════╗
║                    BUILD FAILED                              ║
║                                                              ║
║  Check the logs above for error details.                     ║
╚══════════════════════════════════════════════════════════════╝
'''
        }

        cleanup {
            // Optionally cleanup remote workspace
            sh '''
                echo "Cleanup: Keeping remote workspace for debugging"
                # Uncomment to clean up:
                # ssh -i ${SSH_KEY} ${SSH_USER}@${EC2_HOST} "rm -rf ${REMOTE_WORKSPACE}" || true
            '''
        }
    }
}
