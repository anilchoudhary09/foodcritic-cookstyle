# Application Configuration
# Generated by Chef - compliant-cookbook

[application]
name = <%= @app_name %>
port = <%= @app_port %>
log_level = <%= @log_level %>

[server]
listen = 0.0.0.0:<%= @app_port %>
workers = 4
timeout = 30

[logging]
level = <%= @log_level %>
file = /opt/myapp/logs/app.log
format = json
